# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...                    # service-role key — bypasses RLS (localhost only)

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used by cron.mjs to call local API routes
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Gmail ───────────────────────────────────────────────────────────────────
# For morning/evening briefing emails and weekly habit digest
# App password: https://myaccount.google.com/apppasswords (not your normal password)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx        # 16-char app password with spaces
BRIEFING_NOTIFY_EMAIL=you@gmail.com           # where to deliver briefings (defaults to GMAIL_USER)

# ─── DeepSeek API ────────────────────────────────────────────────────────────
# All agent chat, briefings, email triage. V3 for chat, R1 for research analysis.
# Cost: ~$1.20/month at medium usage. Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# ─── Anthropic API ───────────────────────────────────────────────────────────
# Used ONLY by Paper Digester (Claude Haiku — cheapest for large PDF inputs).
# Cost: ~$0.006/paper. Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Jina AI Embeddings ──────────────────────────────────────────────────────
# Used for ChromaDB vector embeddings (knowledge search + episodic memory).
# Free tier: 1M tokens/month (sufficient for normal use).
# Optional — works without a key on the free tier.
# Get from: https://jina.ai → API Keys
JINA_API_KEY=jina_...

# ─── ChromaDB ────────────────────────────────────────────────────────────────
# Local vector store for Knowledge Agent (RAG over your papers)
# Started automatically by launchd — or manually:
#   /path/to/chroma run --port 8001 --path .chroma-data
CHROMA_URL=http://localhost:8001

# ─── Misc ────────────────────────────────────────────────────────────────────
NEXT_IGNORE_INCORRECT_LOCKFILE=1
