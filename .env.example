# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...          # safe to expose — used client-side
SUPABASE_SERVICE_KEY=eyJ...                    # NEVER expose — server-side only, bypasses RLS

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used by cron.mjs to call local API routes
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Gmail ───────────────────────────────────────────────────────────────────
# For morning/evening briefing emails and weekly habit digest
# App password: https://myaccount.google.com/apppasswords (not your normal password)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx        # 16-char app password with spaces
BRIEFING_NOTIFY_EMAIL=you@gmail.com           # where to deliver briefings (defaults to GMAIL_USER)

# ─── Anthropic API ───────────────────────────────────────────────────────────
# Used ONLY by Paper Digester (Claude Haiku). Budget: ~$0.004/paper.
# Get from: https://console.anthropic.com/settings/keys
# Leave blank to disable auto-digest (papers will still be embedded via Ollama)
ANTHROPIC_API_KEY=sk-ant-...

# ─── ChromaDB ────────────────────────────────────────────────────────────────
# Local vector store for Knowledge Agent (RAG over your papers)
# Started automatically by launchd — or manually:
#   /path/to/chroma run --port 8001 --path .chroma-data
CHROMA_URL=http://localhost:8001

# ─── Ollama ──────────────────────────────────────────────────────────────────
# Local LLM server — install from https://ollama.ai
# Default model: deepseek-r1:7b  (pull with: ollama pull deepseek-r1:7b)
# Knowledge Agent embeddings: nomic-embed-text  (pull with: ollama pull nomic-embed-text)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Misc ────────────────────────────────────────────────────────────────────
NEXT_IGNORE_INCORRECT_LOCKFILE=1
